{
  "name": "claude-omakase",
  "version": "0.7.0",
  "description": "Skill Suggester MCP for Claude — proactive omakase-style skill discovery, installation, and generation.",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "claude-omakase": "dist/server.js",
    "claude-omakase-install": "dist/cli/install.js",
    "omakase": "dist/server.js"
  },
  "files": [
    "dist",
    "omakase-chef",
    "hooks",
    "templates",
    "profiles",
    "handpicked",
    "web/dist",
    "catalog.json",
    "install.sh",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:catalog": "node --enable-source-maps scripts/build-catalog.mjs",
    "enrich:catalog": "node --enable-source-maps scripts/enrich-catalog.mjs",
    "scaffold:adapter": "node scripts/scaffold-adapter.mjs",
    "test:adapter": "node --enable-source-maps scripts/test-adapter.mjs",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src scripts hooks",
    "test": "node --test --import tsx --test-reporter=spec src/**/*.test.ts scripts/*.test.mjs hooks/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify:catalog-rollback": "node scripts/verify-catalog-rollback.mjs",
    "web:server:dev": "node --import tsx/esm --no-warnings src/web-server.ts",
    "web:dev": "concurrently -n api,ui -c blue,green \"npm run web:server:dev\" \"npm --prefix web run dev\"",
    "web:build": "npm run build && npm --prefix web run build",
    "web:start": "node dist/web-server.js",
    "web:install": "npm --prefix web install"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gyuch-an02/claude-omakase.git"
  },
  "keywords": [
    "claude",
    "mcp",
    "model-context-protocol",
    "skill",
    "anthropic"
  ]
}

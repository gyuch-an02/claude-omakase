# Build-time only. Used by `npm run enrich:catalog` to generate skill search_terms
# via a chat LLM. NEVER needed at serving time / by end users. Copy to .env
# (gitignored) and fill in. A generative chat model (gpt-oss, Qwen-Instruct,
# Llama-Instruct) — NOT a text-embedding model.

BASE_URL=http://neuron.uiyunkim.com:11434
MODEL=gpt-oss-120b
# AUTH_TOKEN=                 # optional bearer token if the endpoint requires auth

# Equivalent canonical names (take priority if both set):
# OMAKASE_LLM_URL=http://neuron.uiyunkim.com:11434
# OMAKASE_LLM_MODEL=gpt-oss-120b
# OMAKASE_LLM_KEY=
